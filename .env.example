# Auva Go - Environment Variables

# Database
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/auva-go

# Shared Auva Auth API
NEXT_PUBLIC_AUTH_API_URL=https://auth.auva.dev

# Must match auva-auth JWT access secret for server-side token verification
JWT_ACCESS_SECRET=replace-with-strong-secret

# Public app metadata
NEXT_PUBLIC_APP_URL=https://go.auva.dev
NEXT_PUBLIC_APP_NAME=Auva Go

# Optional: in-memory rate limiting
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000
